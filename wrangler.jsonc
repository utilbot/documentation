{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "utilbot-documentation",
  "compatibility_date": "2026-03-20",
  "assets": {
    "directory": "./dist"
  },
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "custom_domain": true,
      "pattern": "docs.utilbot.co"
    }
  ]
}
